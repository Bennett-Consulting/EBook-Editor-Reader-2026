+    borderRadius: 2,
+    marginBottom: 14,
+  },
+  sheetTitle: { color: theme.textPrimary, fontSize: 18, fontWeight: "600", marginBottom: 12 },
+  row: { flexDirection: "row", alignItems: "center", gap: 10 },
+  counterBtn: {
+    width: 32,
+    height: 32,
+    borderRadius: 16,
+    backgroundColor: theme.surfaceHi,
+    alignItems: "center",
+    justifyContent: "center",
+    borderWidth: 1,
